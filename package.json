{
  "name": "telegram-code-companion",
  "private": true,
  "type": "module",
  "bin": {
    "telegram-code-companion": "./dist/main.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:js": "esbuild src/main.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/main.js --banner:js='#!/usr/bin/env node'",
    "format:fix": "prettier . --write",
    "types:check": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.13",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "grammy": "^1.42.0",
    "zod": "^4.3.6"
  }
}
