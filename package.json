{
  "name": "telegram-code-companion",
  "version": "0.1.0",
  "description": "MCP server that lets your coding agent send you Telegram notifications",
  "keywords": [
    "mcp",
    "telegram",
    "notifications",
    "ai-agent",
    "coding-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loque/telegram-code-companion.git"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "telegram-code-companion": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "npx -y @modelcontextprotocol/inspector bun run --hot src/main.ts",
    "build:js": "esbuild src/main.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/main.js --loader:.md=text --banner:js='#!/usr/bin/env node'",
    "prepublishOnly": "bun run build:js",
    "format:fix": "prettier . --write",
    "types:check": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "knip:fix": "knip --fix --allow-remove-files --format"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "knip": "^6.7.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "grammy": "^1.42.0",
    "zod": "^4.3.6"
  }
}
